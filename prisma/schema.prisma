// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

model User {
  id            String    @id @default(uuid()) @db.Uuid
  name          String
  email         String    @unique
  password      String
  phone         String?
  role          Role      @default(USER)
  activePlanId  String?   @db.Uuid
  activePlan    PricingPlan? @relation(fields: [activePlanId], references: [id])
  planExpiresAt DateTime?
  orders        Order[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("users")
}

enum OrderStatus {
  PENDING
  PAID
  FAILED
}

model Order {
  id              String      @id @default(uuid()) @db.Uuid
  userId          String      @db.Uuid
  user            User        @relation(fields: [userId], references: [id])
  planId          String      @db.Uuid
  plan            PricingPlan @relation(fields: [planId], references: [id])
  merchantOrderId String      @unique
  amount          Int
  status          OrderStatus @default(PENDING)
  duitkuReference String?
  paymentUrl      String?
  paidAt          DateTime?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@map("orders")
}

model PricingPlan {
  id            String                   @id @default(uuid()) @db.Uuid
  key           String                   @unique
  sortOrder     Int                      @default(0)
  popular       Boolean                  @default(false)
  originalPrice Int
  price         Int
  durationDays  Int                      @default(30)
  translations  PricingPlanTranslation[]
  activeUsers   User[]
  orders        Order[]
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt

  @@map("pricing_plans")
}

model PricingPlanTranslation {
  id       String      @id @default(uuid()) @db.Uuid
  planId   String      @db.Uuid
  plan     PricingPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  locale   String
  name     String
  tagline  String
  features Json

  @@unique([planId, locale])
  @@map("pricing_plan_translations")
}
