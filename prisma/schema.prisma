// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  moduleFormat    = "cjs"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
}

model User {
  id                           String    @id @default(uuid()) @db.Uuid
  name                         String
  email                        String    @unique
  password                     String
  phone                        String?
  role                         Role      @default(ADMIN)
  resetPasswordTokenHash       String?   @unique
  resetPasswordTokenExpiresAt  DateTime?
  createdAt                    DateTime  @default(now())
  updatedAt                    DateTime  @updatedAt

  @@map("users")
}

model PricingPlan {
  id            String                   @id @default(uuid()) @db.Uuid
  key           String                   @unique
  sortOrder     Int                      @default(0)
  popular       Boolean                  @default(false)
  originalPrice Int
  price         Int
  translations  PricingPlanTranslation[]
  createdAt     DateTime                 @default(now())
  updatedAt     DateTime                 @updatedAt

  @@map("pricing_plans")
}

model PricingPlanTranslation {
  id       String      @id @default(uuid()) @db.Uuid
  planId   String      @db.Uuid
  plan     PricingPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  locale   String
  name     String
  tagline  String
  features Json

  @@unique([planId, locale])
  @@map("pricing_plan_translations")
}

model AiArticleConfig {
  id            String   @id @default(uuid()) @db.Uuid
  enabled       Boolean  @default(true)
  generateTimes String[]
  weekdayTopics String[]
  weekendTopics String[]
  prompt        String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("ai_article_configs")
}

enum ArticleDayType {
  WEEKDAY
  WEEKEND
}

model Article {
  id           String               @id @default(uuid()) @db.Uuid
  slug         String               @unique
  topic        String
  dayType      ArticleDayType
  imageUrl     String
  seoScore     Int?
  seoFeedback  String?
  translations ArticleTranslation[]
  generatedAt  DateTime             @default(now())
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt

  @@map("articles")
}

model ArticleTranslation {
  id        String  @id @default(uuid()) @db.Uuid
  articleId String  @db.Uuid
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  locale    String
  title     String
  excerpt   String
  content   String[]

  @@unique([articleId, locale])
  @@map("article_translations")
}

model CompanyProfile {
  id           String                      @id @default(uuid()) @db.Uuid
  mapSrc       String
  translations CompanyProfileTranslation[]
  createdAt    DateTime                    @default(now())
  updatedAt    DateTime                    @updatedAt

  @@map("company_profiles")
}

model CompanyProfileTranslation {
  id               String         @id @default(uuid()) @db.Uuid
  companyProfileId String         @db.Uuid
  companyProfile   CompanyProfile @relation(fields: [companyProfileId], references: [id], onDelete: Cascade)
  locale           String
  paragraphs       String[]
  visionEyebrow    String
  missionEyebrow   String
  visionMain       String
  visionAccent     String
  missionItems     Json
  contactInfoCards Json

  @@unique([companyProfileId, locale])
  @@map("company_profile_translations")
}

model SiteSetting {
  id          String   @id @default(uuid()) @db.Uuid
  locale      String   @unique
  hero        Json
  problem     Json
  omnichannel Json
  aiCrm       Json
  whyChatHub  Json
  industries  Json
  closingCta  Json
  faq         Json
  footer      Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("site_settings")
}

model CompanyLogo {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  imageUrl  String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@map("company_logos")
}

model ContactSubmission {
  id        String   @id @default(uuid()) @db.Uuid
  name      String
  email     String
  phone     String?
  message   String
  createdAt DateTime @default(now())

  @@map("contact_submissions")
}
