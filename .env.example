# Environment variables declared in this file are NOT automatically loaded by Prisma.
# Please add `import "dotenv/config";` to your `prisma.config.ts` file, or use the Prisma CLI with Bun
# to load environment variables from .env files: https://pris.ly/prisma-config-env-vars.

# Prisma supports the native connection string format for PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.
# See the documentation for all the connection string options: https://pris.ly/d/connection-strings

DATABASE_URL="postgresql://postgres:postgres@localhost:5432/inchathub?schema=public"
PORT=3000
JWT_SECRET="change-me-to-a-long-random-string"
JWT_EXPIRES_IN="7d"
CLIENT_ORIGIN="http://localhost:3000"

# Duitku payment gateway (sandbox credentials from https://sandbox.duitku.com)
DUITKU_ENV="sandbox"
DUITKU_MERCHANT_CODE=""
DUITKU_API_KEY=""

# Publicly reachable URL of this backend, used to build the Duitku callback
# URL. In local dev this must be a tunnel (e.g. ngrok) since Duitku calls it
# from the internet — localhost will not work. Also used to build public
# URLs for AI-generated article images served from /uploads.
API_PUBLIC_URL="http://localhost:4000"

# OpenRouter — used to auto-generate blog articles (text + cover image).
OPENROUTER_API_KEY=""
OPENROUTER_TEXT_MODEL="openai/gpt-4o-mini"
OPENROUTER_IMAGE_MODEL="google/gemini-2.5-flash-image-preview"


# SMTP for sending password-reset emails. Without these, forgot-password
# still works but the email is only logged to the console, not sent.
# Quick options: Gmail (use an App Password, not your login password) or a
# dev-friendly provider like Resend/Mailtrap's SMTP endpoint.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email-address
SMTP_PASS=xxxx xxxx xxxx xxxx
SMTP_FROM="ChatHub <your-email-address>"